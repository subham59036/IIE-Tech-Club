# ─────────────────────────────────────────────────────────────────────────────
# TechOS – Environment Variables Template
# Copy this file to .env.local and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Turso Database (auto-filled by Vercel's Turso Integration) ────────────────
# After connecting Turso in Vercel dashboard, pull env vars:
#   vercel env pull .env.local
TURSO_DATABASE_URL=TURSO_DATABASE_URL
TURSO_AUTH_TOKEN=TURSO_AUTH_TOKEN

# ── JWT Secret (CHANGE THIS — generate with: openssl rand -hex 64) ────────────
JWT_SECRET=JWT_SECRET

# ── Cron Secret (any random string — used to protect /api/cron/cleanup) ──────
# Set the same value in Vercel → Settings → Environment Variables
CRON_SECRET=CRON_SECRET

# ── IP Salt (any random string — used to hash IPs for rate-limiting) ─────────
IP_SALT=IP_SALT

# ── App public URL (your Vercel deployment domain) ────────────────────────────
# Used to build the event registration form share link
NEXT_PUBLIC_APP_URL=https://iie-tech-os.vercel.app
